# ============================================================
# HostMyEvent Backend — Environment Variables Template
# Copy this file to .env and fill in real values
# ============================================================

# Database
DB_URL=jdbc:mysql://<host>:<port>/<db_name>?sslMode=VERIFY_IDENTITY&sslTrustStoreUrl=system
DB_USERNAME=
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRATION=86400000

# Pinata IPFS
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT_KEY=

# SMTP
SMTP_USERNAME=
SMTP_PASSWORD=

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173
